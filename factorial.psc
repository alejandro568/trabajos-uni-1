Proceso Factorial
    Definir numero, i Como Entero
    Definir factorial Como Entero
	
    Escribir "Ingrese un número entero positivo:"
    Leer numero
	
    factorial <- 1
	
    Para i <- 1 Hasta numero Hacer
        factorial <- factorial * i
    FinPara
	
    Escribir "El factorial de ", numero, " es: ", factorial
	
FinProceso